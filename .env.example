
# Provider selection 
QUEUE_PROVIDER=kafka        # kafka | memory
STORE_PROVIDER=clickhouse   # clickhouse | memory

# Ingest service
INGEST_HTTP_PORT=4318
INGEST_GRPC_PORT=4317
OPS_PORT=9464

# Redpanda (Kafka API)
KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=heliograph
TOPIC_METRICS=canonical.metrics
TOPIC_EVENTS=canonical.events
TOPIC_DLQ=canonical.dlq

# ClickHouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DB=heliograph
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Read API
READ_API_PORT=8080

# Redaction / privacy
# Secret used to pseudonymize identity (HMAC pepper). MUST be set in production.
IDENTITY_PEPPER=dev-only-change-me
# Global default for content capture. Per-org policy can override, but never
# loosen `critical` fields unless captureContent is true for that org.
DEFAULT_CAPTURE_CONTENT=false
