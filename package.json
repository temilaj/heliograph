{
  "name": "heliograph",
  "version": "0.0.1",
  "private": true,
  "description": "Telemetry ingestion for AI coding tools (OpenTelemetry). Claude Code first.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "tools/*"
  ],
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit && tsc --noEmit -p apps/dashboard",
    "test": "bun test",
    "ingest": "bun run apps/ingest/src/main.ts",
    "processor": "bun run apps/processor/src/main.ts",
    "read-api": "bun run apps/read-api/src/main.ts",
    "loadgen": "bun run tools/loadgen/src/main.ts",
    "directory:load": "bun run tools/directory-loader/src/main.ts",
    "migrate": "bun run packages/storage/src/migrate.ts",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down -v"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "kafkajs": "^2.2.4",
    "protobufjs": "^8.7.0"
  }
}
